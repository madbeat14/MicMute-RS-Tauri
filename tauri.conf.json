{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "MicMuteRs",
    "version": "0.1.0",
    "identifier": "com.madbeat14.micmuters",
    "build": {
        "frontendDist": "src/frontend"
    },
    "app": {
        "windows": [
            {
                "label": "settings",
                "title": "MicMuteRs Settings",
                "url": "index.html",
                "width": 580,
                "height": 600,
                "minWidth": 480,
                "minHeight": 300,
                "resizable": true,
                "decorations": true,
                "transparent": false,
                "visible": false,
                "skipTaskbar": false,
                "additionalBrowserArgs": "--disable-features=HardwareMediaKeyHandling"
            },
            {
                "label": "overlay",
                "title": "MicMuteRs Overlay",
                "url": "overlay.html",
                "width": 48,
                "height": 48,
                "resizable": false,
                "decorations": false,
                "transparent": true,
                "visible": false,
                "alwaysOnTop": true,
                "skipTaskbar": true,
                "acceptFirstMouse": false,
                "additionalBrowserArgs": "--disable-features=HardwareMediaKeyHandling"
            },
            {
                "label": "osd",
                "title": "MicMuteRs OSD",
                "url": "osd.html",
                "width": 200,
                "height": 200,
                "resizable": false,
                "decorations": false,
                "transparent": true,
                "visible": false,
                "alwaysOnTop": true,
                "skipTaskbar": true,
                "additionalBrowserArgs": "--disable-features=HardwareMediaKeyHandling"
            }
        ],
        "withGlobalTauri": true,
        "security": {
            "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self'; media-src 'self'"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "src/frontend/assets/mic_white.ico"
        ],
        "windows": {
            "wix": {},
            "nsis": {}
        }
    },
    "plugins": {
        "dialog": null
    }
}